{
  "name": "opa-admin-layer-dev",
  "controlPlane": {
    "baseServiceURL": "https://control.example.com",
    "bundlePrefix": "bundles",
    "defaultDecisionPath": "system/authz/allow",
    "defaultListenAddress": ":8181",
    "opaImage": "openpolicyagent/opa:1.12.1",
    "namespace": "policy-system",
    "serviceType": "ClusterIP",
    "internalTrafficPolicy": "Cluster",
    "sessionAffinity": "ClientIP",
    "serviceAnnotations": {
      "example.com/health-check-path": "/health?plugins"
    },
    "podAnnotations": {
      "sidecar.istio.io/inject": "false",
      "example.com/trace-sampling": "shared"
    },
    "opaResources": {
      "requests": {
        "cpu": "100m",
        "memory": "128Mi"
      },
      "limits": {
        "memory": "512Mi"
      }
    }
  },
  "tenants": [
    {
      "name": "tenant-a",
      "topics": [
        {
          "name": "billing",
          "labels": {
            "environment": "dev",
            "owner": "platform"
          },
          "serviceType": "NodePort",
          "externalTrafficPolicy": "Local",
          "internalTrafficPolicy": "Local",
          "sessionAffinity": "None",
          "serviceAnnotations": {
            "example.com/exposure": "public",
            "example.com/health-check-path": "/billing-health"
          },
          "podAnnotations": {
            "example.com/trace-sampling": "billing",
            "example.com/debug": "enabled"
          },
          "opaResources": {
            "requests": {
              "memory": "256Mi"
            }
          }
        },
        {"name": "support", "decisionPath": "support/authz/allow"}
      ]
    },
    {
      "name": "tenant-b",
      "topics": [
        {"name": "catalog"}
      ]
    }
  ]
}
