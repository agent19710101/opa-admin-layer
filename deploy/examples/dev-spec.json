{
  "name": "opa-admin-layer-dev",
  "controlPlane": {
    "baseServiceURL": "https://control.example.com",
    "bundlePrefix": "bundles",
    "defaultDecisionPath": "system/authz/allow",
    "defaultListenAddress": ":8181",
    "opaImage": "openpolicyagent/opa:1.12.1",
    "namespace": "policy-system",
    "replicas": 2,
    "serviceType": "ClusterIP",
    "internalTrafficPolicy": "Cluster",
    "sessionAffinity": "ClientIP",
    "serviceAnnotations": {
      "example.com/health-check-path": "/health?plugins"
    },
    "serviceLabels": {
      "example.com/service-scope": "shared",
      "example.com/team": "platform"
    },
    "configMapAnnotations": {
      "reloader.stakater.com/match": "true"
    },
    "deploymentAnnotations": {
      "example.com/owner": "platform",
      "example.com/revision-window": "shared"
    },
    "deploymentLabels": {
      "example.com/release-track": "shared",
      "example.com/team": "platform"
    },
    "podAnnotations": {
      "sidecar.istio.io/inject": "false",
      "example.com/trace-sampling": "shared"
    },
    "podLabels": {
      "example.com/workload-class": "shared",
      "example.com/team": "platform"
    },
    "serviceAccountName": "opa-shared",
    "imagePullPolicy": "IfNotPresent",
    "automountServiceAccountToken": false,
    "opaResources": {
      "requests": {
        "cpu": "100m",
        "memory": "128Mi"
      },
      "limits": {
        "memory": "512Mi"
      }
    },
    "configMapLabels": {
      "example.com/config-scope": "shared",
      "example.com/team": "platform"
    }
  },
  "tenants": [
    {
      "name": "tenant-a",
      "topics": [
        {
          "name": "billing",
          "labels": {
            "environment": "dev",
            "owner": "platform"
          },
          "replicas": 4,
          "serviceType": "NodePort",
          "externalTrafficPolicy": "Local",
          "internalTrafficPolicy": "Local",
          "sessionAffinity": "None",
          "serviceAnnotations": {
            "example.com/exposure": "public",
            "example.com/health-check-path": "/billing-health"
          },
          "serviceLabels": {
            "example.com/service-scope": "billing",
            "example.com/ring": "canary"
          },
          "removeServiceLabels": [
            "example.com/team"
          ],
          "configMapAnnotations": {
            "example.com/source": "billing",
            "example.com/team": "payments"
          },
          "deploymentAnnotations": {
            "example.com/revision-window": "billing",
            "example.com/rollout": "canary"
          },
          "deploymentLabels": {
            "example.com/release-track": "billing",
            "example.com/ring": "canary"
          },
          "podAnnotations": {
            "example.com/trace-sampling": "billing",
            "example.com/debug": "enabled"
          },
          "podLabels": {
            "example.com/workload-class": "billing",
            "example.com/team": "payments"
          },
          "serviceAccountName": "billing-opa",
          "imagePullPolicy": "Always",
          "automountServiceAccountToken": true,
          "opaResources": {
            "requests": {
              "memory": "256Mi"
            }
          },
          "configMapLabels": {
            "example.com/config-scope": "billing",
            "example.com/ring": "canary"
          }
        },
        {
          "name": "support",
          "decisionPath": "support/authz/allow"
        }
      ]
    },
    {
      "name": "tenant-b",
      "topics": [
        {
          "name": "catalog"
        }
      ]
    }
  ]
}
